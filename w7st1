<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeuFlow - Neumorphic Music Player</title>
    
    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            /* Light Theme (Default) */
            --bg-color: #e0e5ec;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --shadow-light: #ffffff;
            --shadow-dark: #a3b1c6;
            --primary: #6c5ce7;
            --primary-glow: rgba(108, 92, 231, 0.4);
            --danger: #ff7675;
        }

        .dark {
            /* Dark Theme */
            --bg-color: #2b2e33;
            --text-main: #f5f6fa;
            --text-muted: #a4b0be;
            --shadow-light: #363a40;
            --shadow-dark: #202226;
            --primary: #a29bfe;
            --primary-glow: rgba(162, 155, 254, 0.4);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: background-color 0.4s ease, color 0.4s ease;
        }

        /* --- NEUMORPHIC UTILITIES --- */
        .neu-flat {
            background: var(--bg-color);
            box-shadow: 8px 8px 16px var(--shadow-dark), -8px -8px 16px var(--shadow-light);
            border-radius: 20px;
        }

        .neu-inset {
            background: var(--bg-color);
            box-shadow: inset 6px 6px 12px var(--shadow-dark), inset -6px -6px 12px var(--shadow-light);
            border-radius: 20px;
        }

        .neu-button {
            background: var(--bg-color);
            box-shadow: 5px 5px 10px var(--shadow-dark), -5px -5px 10px var(--shadow-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border: none;
            color: var(--text-main);
            transition: all 0.2s ease;
            outline: none;
        }

        .neu-button:hover {
            color: var(--primary);
        }

        .neu-button:active, .neu-button.active {
            box-shadow: inset 4px 4px 8px var(--shadow-dark), inset -4px -4px 8px var(--shadow-light);
            color: var(--primary);
        }

        .neu-text-inset {
            color: transparent;
            text-shadow: 1px 1px 1px var(--shadow-light), -1px -1px 1px var(--shadow-dark);
            background-clip: text;
            -webkit-background-clip: text;
        }

        /* --- LAYOUT --- */
        .app-container {
            display: flex;
            flex: 1;
            overflow: hidden;
            padding: 20px;
            gap: 30px;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            flex-shrink: 0;
        }
        @media (max-width: 900px) { .sidebar { display: none; } }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 20px;
            font-size: 24px;
            font-weight: 700;
            color: var(--primary);
        }

        .nav-menu {
            list-style: none;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .nav-item {
            padding: 12px 20px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 15px;
            color: var(--text-muted);
            transition: all 0.3s ease;
        }
        .nav-item:hover, .nav-item.active {
            color: var(--primary);
            box-shadow: inset 4px 4px 8px var(--shadow-dark), inset -4px -4px 8px var(--shadow-light);
        }

        /* Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 30px;
            overflow-y: auto;
            padding-right: 10px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .search-bar {
            flex: 1;
            max-width: 400px;
            display: flex;
            align-items: center;
            padding: 0 20px;
            height: 50px;
            border-radius: 25px;
        }
        .search-bar input {
            flex: 1;
            border: none;
            background: transparent;
            outline: none;
            color: var(--text-main);
            padding-left: 15px;
            font-size: 16px;
        }

        /* Hero / Player Section */
        .hero-section {
            display: flex;
            gap: 40px;
            padding: 40px;
            align-items: center;
        }
        @media (max-width: 768px) { 
            .hero-section { flex-direction: column; text-align: center; padding: 20px; }
        }

        .visualizer-container {
            position: relative;
            width: 250px;
            height: 250px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            box-shadow: 12px 12px 24px var(--shadow-dark), -12px -12px 24px var(--shadow-light);
            padding: 10px;
        }

        canvas#freq-canvas {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            border-radius: 50%;
            z-index: 1;
            pointer-events: none;
        }

        .album-art-wrap {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            overflow: hidden;
            z-index: 2;
            position: relative;
            border: 4px solid var(--bg-color);
            box-shadow: inset 4px 4px 8px rgba(0,0,0,0.5);
            animation: spin 20s linear infinite;
            animation-play-state: paused;
        }
        .album-art-wrap.playing {
            animation-play-state: running;
        }
        @keyframes spin { 100% { transform: rotate(360deg); } }

        .album-art-wrap img {
            width: 100%; height: 100%;
            object-fit: cover;
        }

        .hero-info { flex: 1; }
        .hero-title { font-size: 42px; font-weight: 700; margin-bottom: 5px; }
        .hero-artist { font-size: 20px; color: var(--text-muted); margin-bottom: 20px; }

        /* Playlist */
        .playlist-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
            padding: 20px;
        }
        
        .song-row {
            display: grid;
            grid-template-columns: 40px 1fr 2fr 80px 50px;
            align-items: center;
            padding: 15px 20px;
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.2s;
            gap: 15px;
        }
        @media (max-width: 600px) {
            .song-row { grid-template-columns: 40px 1fr 50px; }
            .song-album { display: none; }
            .song-duration { display: none; }
        }

        .song-row:hover {
            box-shadow: 4px 4px 8px var(--shadow-dark), -4px -4px 8px var(--shadow-light);
        }
        .song-row.active {
            box-shadow: inset 4px 4px 8px var(--shadow-dark), inset -4px -4px 8px var(--shadow-light);
            color: var(--primary);
        }

        .song-img {
            width: 40px; height: 40px;
            border-radius: 8px;
            object-fit: cover;
            box-shadow: 2px 2px 5px var(--shadow-dark);
        }
        .song-title-group h4 { font-size: 15px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .song-title-group p { font-size: 12px; color: var(--text-muted); }
        .fav-btn { color: var(--text-muted); font-size: 18px; border: none; background: transparent; cursor: pointer; }
        .fav-btn.is-fav { color: var(--danger); }

        /* Right Panel (Lyrics / Recents) */
        .right-panel {
            width: 300px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            flex-shrink: 0;
            padding: 20px;
        }
        @media (max-width: 1200px) { .right-panel { display: none; } }

        .lyrics-box {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            text-align: center;
            line-height: 2;
            font-size: 15px;
            color: var(--text-muted);
            border-radius: 20px;
        }
        .lyric-line.active {
            color: var(--primary);
            font-size: 18px;
            font-weight: 600;
            text-shadow: 0 0 10px var(--primary-glow);
            transform: scale(1.05);
            transition: all 0.3s;
        }

        /* Bottom Player Bar */
        .player-bar {
            height: 100px;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            z-index: 10;
        }
        @media (max-width: 768px) {
            .player-bar { padding: 0 15px; height: 120px; flex-direction: column; justify-content: center; gap: 10px; }
            .volume-control { display: none !important; }
            .player-track-info { display: none !important; }
        }

        .player-controls {
            display: flex;
            align-items: center;
            gap: 20px;
            flex: 1;
            justify-content: center;
        }

        .btn-main { width: 60px; height: 60px; font-size: 24px; color: var(--primary); }
        .btn-sub { width: 45px; height: 45px; font-size: 16px; }

        .progress-container {
            width: 100%;
            max-width: 500px;
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-muted);
        }

        /* Custom Neumorphic Range Sliders */
        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: transparent;
            height: 20px;
            outline: none;
        }
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 8px;
            border-radius: 4px;
            background: var(--bg-color);
            box-shadow: inset 2px 2px 5px var(--shadow-dark), inset -2px -2px 5px var(--shadow-light);
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 20px;
            width: 20px;
            border-radius: 50%;
            background: var(--bg-color);
            box-shadow: 2px 2px 5px var(--shadow-dark), -2px -2px 5px var(--shadow-light);
            margin-top: -6px;
            cursor: pointer;
            border: 2px solid var(--primary);
        }
        input[type=range]:active::-webkit-slider-thumb {
            background: var(--primary);
        }

        .volume-control {
            display: flex;
            align-items: center;
            gap: 15px;
            width: 200px;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--shadow-dark); border-radius: 4px; }

        /* Toasts */
        .toast-container { position: fixed; top: 20px; right: 20px; z-index: 1000; display: flex; flex-direction: column; gap: 10px; }
        .toast {
            padding: 15px 25px;
            border-radius: 12px;
            background: var(--bg-color);
            box-shadow: 4px 4px 10px var(--shadow-dark), -4px -4px 10px var(--shadow-light);
            animation: slideIn 0.3s ease forwards;
            font-weight: 500;
        }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

        /* Loading Spinner */
        .loader {
            border: 3px solid var(--shadow-light);
            border-top: 3px solid var(--primary);
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spinn 1s linear infinite;
            display: none;
        }
        .is-loading .loader { display: block; }
        .is-loading .fa-play { display: none; }
        @keyframes spinn { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    </style>
</head>
<body>

    <!-- Toast Notifications -->
    <div class="toast-container" id="toast-box"></div>

    <!-- MAIN APP WRAPPER -->
    <div class="app-container">
        
        <aside class="sidebar neu-flat">
            <div class="logo">
                <div class="neu-button" style="width: 40px; height: 40px;"><i class="fa-solid fa-music"></i></div>
                NeuFlow
            </div>
            
            <ul class="nav-menu">
                <li class="nav-item active" onclick="app.setMenu('home')"><i class="fa-solid fa-house"></i> Home</li>
                <li class="nav-item" onclick="app.setMenu('favorites')"><i class="fa-solid fa-heart"></i> Favorites</li>
                <li class="nav-item" onclick="app.setMenu('recent')"><i class="fa-solid fa-clock-rotate-left"></i> Recent</li>
            </ul>

            <div style="padding: 0 20px; margin-top: 10px; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase;">Categories</div>
            <ul class="nav-menu" style="padding-top: 10px; overflow-y: auto;" id="category-list">
                <!-- Categories populated by JS -->
            </ul>

            <div style="margin-top: auto; padding: 20px;">
                <button class="nav-item neu-inset w-100" style="width: 100%; border: none; justify-content: center;" onclick="app.toggleTheme()">
                    <i class="fa-solid fa-moon" id="theme-icon"></i> <span id="theme-text">Dark Mode</span>
                </button>
            </div>
        </aside>

        <main class="main-content">
            <header class="header">
                <div class="search-bar neu-inset">
                    <i class="fa-solid fa-search" style="color: var(--text-muted);"></i>
                    <input type="text" id="search-input" placeholder="Search song, artist, album...">
                </div>
                
                <!-- Mobile Menu Trigger -->
                <button class="neu-button" style="width: 50px; height: 50px; display: none;" id="mobile-menu-btn">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </header>

            <!-- Hero Section -->
            <section class="hero-section neu-flat">
                <!-- The Canvas Visualizer wraps the Album Art -->
                <div class="visualizer-container">
                    <canvas id="freq-canvas"></canvas>
                    <div class="album-art-wrap" id="hero-album-wrap">
                        <img id="hero-cover" src="https://images.unsplash.com/photo-1614680376593-902f74cf0d41?q=80&w=500&auto=format&fit=crop" alt="Cover">
                    </div>
                </div>
                
                <div class="hero-info">
                    <div style="color: var(--primary); font-weight: 600; margin-bottom: 10px; font-size: 14px; text-transform: uppercase; letter-spacing: 2px;">Now Playing</div>
                    <h2 class="hero-title" id="hero-title">Select a Song</h2>
                    <p class="hero-artist" id="hero-artist">Artist Name</p>
                    
                    <div style="display: flex; gap: 15px;">
                        <button class="neu-button" style="padding: 12px 25px; border-radius: 25px; width: auto; color: var(--primary); font-weight: 600;" onclick="app.togglePlay()">
                            <i class="fa-solid fa-play" style="margin-right: 8px;"></i> Play Now
                        </button>
                        <button class="neu-button" style="width: 45px; height: 45px;" id="hero-fav-btn" onclick="app.toggleFavCurrent()">
                            <i class="fa-regular fa-heart"></i>
                        </button>
                    </div>
                </div>
            </section>

            <!-- Playlist Area -->
            <div>
                <h3 style="margin: 10px 20px; font-size: 20px; font-weight: 600;" id="list-title">All Songs</h3>
                <div class="playlist-container neu-flat" id="playlist-box">
                    <!-- Songs populated by JS -->
                </div>
            </div>
        </main>

        <aside class="right-panel neu-flat">
            <h3 style="font-size: 18px; font-weight: 600; text-align: center; color: var(--primary); padding-bottom: 15px; border-bottom: 2px solid var(--shadow-light);">
                <i class="fa-solid fa-microphone-lines"></i> Lyrics
            </h3>
            <div class="lyrics-box neu-inset" id="lyrics-container">
                <p>Play a song to view lyrics.</p>
            </div>
            
            <div style="margin-top: auto;">
                <div class="neu-flat" style="padding: 15px; text-align: center; border-radius: 15px;">
                    <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Equalizer Mode</p>
                    <div style="display: flex; justify-content: center; gap: 15px;">
                        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--primary); box-shadow: 0 0 10px var(--primary);"></span>
                        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--danger); box-shadow: 0 0 10px var(--danger);"></span>
                        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #00cec9; box-shadow: 0 0 10px #00cec9;"></span>
                    </div>
                </div>
            </div>
        </aside>

    </div> <!-- End App Container -->

    <footer class="player-bar neu-flat" style="border-radius: 20px 20px 0 0;">
        
        <div class="player-track-info" style="display: flex; align-items: center; gap: 15px; width: 250px;">
            <img id="bar-cover" src="https://via.placeholder.com/50" style="width: 50px; height: 50px; border-radius: 10px; box-shadow: 3px 3px 6px var(--shadow-dark);">
            <div style="overflow: hidden;">
                <h4 id="bar-title" style="font-size: 14px; font-weight: 600; white-space: nowrap; text-overflow: ellipsis; overflow: hidden;">Track Title</h4>
                <p id="bar-artist" style="font-size: 12px; color: var(--text-muted);">Artist</p>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px; flex: 1; max-width: 600px;">
            <!-- Controls -->
            <div class="player-controls">
                <button class="neu-button btn-sub" id="btn-shuffle" onclick="app.toggleShuffle()"><i class="fa-solid fa-shuffle"></i></button>
                <button class="neu-button btn-sub" onclick="app.prev()"><i class="fa-solid fa-backward-step"></i></button>
                
                <button class="neu-button btn-main" id="btn-play" onclick="app.togglePlay()">
                    <i class="fa-solid fa-play"></i>
                    <div class="loader"></div>
                </button>
                
                <button class="neu-button btn-sub" onclick="app.next()"><i class="fa-solid fa-forward-step"></i></button>
                <button class="neu-button btn-sub" id="btn-repeat" onclick="app.toggleRepeat()"><i class="fa-solid fa-repeat"></i></button>
            </div>
            
            <!-- Timeline -->
            <div class="progress-container">
                <span id="time-cur">0:00</span>
                <input type="range" id="seek-bar" value="0" min="0" max="100" step="0.1">
                <span id="time-tot">0:00</span>
            </div>
        </div>

        <div class="volume-control">
            <button class="neu-button btn-sub" id="btn-mute" onclick="app.toggleMute()" style="width: 35px; height: 35px; font-size: 14px;"><i class="fa-solid fa-volume-high"></i></button>
            <input type="range" id="vol-bar" value="100" min="0" max="100">
        </div>
    </footer>

    <audio id="audio-core"></audio>

    <script>
        /** MUSIC DATABASE (Public Domain / CC0 simulated tracks) */
        const DB = [
            { id: '1', title: 'Summer Breeze', artist: 'The Beach Boys', album: 'Sunshine', duration: '03:12', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3', cover: 'https://images.unsplash.com/photo-1493225457124-a1a2a5956093?q=80&w=300&auto=format&fit=crop', category: 'Pop', lyrics: ["Oh the summer breeze", "Blowing through my mind", "Golden sun above", "Leaving cares behind...", "Yeah, we are flying high"] },
            { id: '2', title: 'Midnight Rock', artist: 'Neon Shadows', album: 'Night Drive', duration: '07:05', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3', cover: 'https://images.unsplash.com/photo-1498038432885-c6f3f1b912ee?q=80&w=300&auto=format&fit=crop', category: 'Rock', lyrics: ["City lights flash by", "Engine roaring loud", "Midnight rocker", "Standing in the crowd", "We won't stop tonight"] },
            { id: '3', title: 'Chill Lo-Fi', artist: 'Lofi Girl', album: 'Study Session', duration: '05:44', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3', cover: 'https://images.unsplash.com/photo-1511379938547-c1f69419868d?q=80&w=300&auto=format&fit=crop', category: 'Lo-Fi', lyrics: ["(Instrumental intro)", "Rain patters on the window...", "Breathe in...", "Breathe out...", "Focus your mind"] },
            { id: '4', title: 'Classical Symphony', artist: 'Beethoven', album: 'Masterpieces', duration: '05:02', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3', cover: 'https://images.unsplash.com/photo-1507838153414-b4b713384a76?q=80&w=300&auto=format&fit=crop', category: 'Classical', lyrics: ["Freude, schöner Götterfunken", "Tochter aus Elysium", "Wir betreten feuertrunken", "Himmlische, dein Heiligtum!"] },
            { id: '5', title: 'Jazz Club Vibes', artist: 'Duke Smooth', album: 'Late Night', duration: '06:08', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-5.mp3', cover: 'https://images.unsplash.com/photo-1514525253161-7a46d19cd819?q=80&w=300&auto=format&fit=crop', category: 'Jazz', lyrics: ["Da ba dee", "Ba ba dow", "(Saxophone solo playing softly)", "Smooth as silk...", "Take it easy now"] },
            { id: '6', title: 'Electric Dreams', artist: 'DJ Pulse', album: 'Rave 2026', duration: '04:12', src: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-6.mp3', cover: 'https://images.unsplash.com/photo-1571266028243-cb40fce75737?q=80&w=300&auto=format&fit=crop', category: 'EDM', lyrics: ["Are you ready?", "1, 2, 3...", "Drop the bass!", "(Heavy synth sounds)", "Jump! Jump! Jump!"] }
        ];

        /** MAIN APPLICATION LOGIC */
        const app = {
            audio: document.getElementById('audio-core'),
            state: {
                list: [...DB],
                index: 0,
                isPlaying: false,
                isShuffle: JSON.parse(localStorage.getItem('neu_shuffle')) || false,
                repeatMode: parseInt(localStorage.getItem('neu_repeat')) || 0, // 0: off, 1: all, 2: one
                favorites: JSON.parse(localStorage.getItem('neu_favs')) || [],
                recent: JSON.parse(localStorage.getItem('neu_recent')) || [],
                view: 'home' // home, favorites, recent, category
            },
            
            init() {
                // Theme setup
                if(JSON.parse(localStorage.getItem('neu_dark'))) this.toggleTheme(true);
                
                // Volume setup
                const vol = localStorage.getItem('neu_vol');
                if(vol !== null) {
                    this.audio.volume = vol;
                    document.getElementById('vol-bar').value = vol * 100;
                }

                // Populate UI
                this.renderCategories();
                this.renderList();
                
                // Load last song
                const lastId = localStorage.getItem('neu_last');
                if(lastId) {
                    const idx = DB.findIndex(s => s.id === lastId);
                    if(idx !== -1) this.state.index = idx;
                }
                this.loadSong(this.state.list[this.state.index], false);
                this.updateControlButtons();

                // Bind Events
                this.bindEvents();
                Visualizer.init(); // Start Visualizer setup
            },

            loadSong(song, autoPlay = true) {
                if(!song) return;
                
                // Update text/images
                document.getElementById('hero-title').textContent = song.title;
                document.getElementById('hero-artist').textContent = song.artist;
                document.getElementById('hero-cover').src = song.cover;
                
                document.getElementById('bar-title').textContent = song.title;
                document.getElementById('bar-artist').textContent = song.artist;
                document.getElementById('bar-cover').src = song.cover;

                this.renderLyrics(song);
                this.updateFavIcon();
                
                // Highlight list
                document.querySelectorAll('.song-row').forEach(el => el.classList.remove('active'));
                const row = document.getElementById(`song-${song.id}`);
                if(row) row.classList.add('active');

                // Set Audio
                if(this.audio.src !== song.src) {
                    document.getElementById('btn-play').classList.add('is-loading');
                    this.audio.src = song.src;
                    this.audio.load();
                }

                localStorage.setItem('neu_last', song.id);

                if(autoPlay) {
                    this.addToRecent(song);
                    this.play();
                } else {
                    this.updateTimeUI();
                }
            },

            play() {
                this.state.isPlaying = true;
                const icon = document.querySelector('#btn-play i');
                icon.className = 'fa-solid fa-pause';
                document.getElementById('btn-play').classList.add('neu-pressed');
                document.getElementById('hero-album-wrap').classList.add('playing');
                
                const p = this.audio.play();
                if(p !== undefined) {
                    p.catch(() => {
                        this.pause();
                        this.toast("Interaction required to auto-play");
                    });
                }
                this.toast(`Now Playing: ${this.state.list[this.state.index].title}`);
                Visualizer.start();
            },

            pause() {
                this.state.isPlaying = false;
                const icon = document.querySelector('#btn-play i');
                icon.className = 'fa-solid fa-play';
                document.getElementById('btn-play').classList.remove('neu-pressed');
                document.getElementById('hero-album-wrap').classList.remove('playing');
                this.audio.pause();
                Visualizer.stop();
            },

            togglePlay() {
                if(this.audio.readyState === 0) this.loadSong(this.state.list[this.state.index], true);
                else this.state.isPlaying ? this.pause() : this.play();
            },

            next() {
                if(this.state.isShuffle) {
                    let nextIdx;
                    do { nextIdx = Math.floor(Math.random() * this.state.list.length); } 
                    while (nextIdx === this.state.index && this.state.list.length > 1);
                    this.state.index = nextIdx;
                } else {
                    this.state.index = (this.state.index + 1) % this.state.list.length;
                }
                this.loadSong(this.state.list[this.state.index]);
            },

            prev() {
                if(this.audio.currentTime > 3) {
                    this.audio.currentTime = 0;
                } else {
                    this.state.index = (this.state.index - 1 + this.state.list.length) % this.state.list.length;
                    this.loadSong(this.state.list[this.state.index]);
                }
            },

            setMenu(viewType, filterData = null) {
                this.state.view = viewType;
                document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
                
                // Update active state in sidebar (simple match)
                event && event.currentTarget && event.currentTarget.classList.add('active');

                if(viewType === 'home') {
                    this.state.list = [...DB];
                    document.getElementById('list-title').textContent = "All Songs";
                } else if (viewType === 'favorites') {
                    this.state.list = [...this.state.favorites];
                    document.getElementById('list-title').textContent = "My Favorites";
                } else if (viewType === 'recent') {
                    this.state.list = [...this.state.recent];
                    document.getElementById('list-title').textContent = "Recently Played";
                } else if (viewType === 'category') {
                    this.state.list = DB.filter(s => s.category === filterData);
                    document.getElementById('list-title').textContent = `${filterData} Tracks`;
                }

                this.renderList();
            },

            search(query) {
                query = query.toLowerCase();
                this.state.list = DB.filter(s => 
                    s.title.toLowerCase().includes(query) || 
                    s.artist.toLowerCase().includes(query)
                );
                document.getElementById('list-title').textContent = query ? `Search: "${query}"` : "All Songs";
                this.renderList();
            },

            renderList() {
                const box = document.getElementById('playlist-box');
                box.innerHTML = '';
                
                if(this.state.list.length === 0) {
                    box.innerHTML = `<div style="text-align:center; padding: 30px; color: var(--text-muted);">No tracks found.</div>`;
                    return;
                }

                this.state.list.forEach((song, i) => {
                    const isActive = (song.id === DB[this.state.index]?.id);
                    const isFav = this.state.favorites.some(s => s.id === song.id);
                    
                    const el = document.createElement('div');
                    el.className = `song-row neu-inset ${isActive ? 'active' : ''}`;
                    el.id = `song-${song.id}`;
                    el.innerHTML = `
                        <div style="text-align:center; font-weight:600; color:var(--text-muted);" onclick="app.playSpecific('${song.id}')">${i+1}</div>
                        <div style="display:flex; gap:15px; align-items:center; overflow:hidden;" onclick="app.playSpecific('${song.id}')">
                            <img src="${song.cover}" class="song-img">
                            <div class="song-title-group">
                                <h4>${song.title}</h4>
                                <p>${song.artist}</p>
                            </div>
                        </div>
                        <div class="song-album" style="color:var(--text-muted); font-size:13px;" onclick="app.playSpecific('${song.id}')">${song.album}</div>
                        <div class="song-duration" style="color:var(--text-muted); font-size:13px;" onclick="app.playSpecific('${song.id}')">${song.duration}</div>
                        <button class="fav-btn ${isFav ? 'is-fav' : ''}" onclick="app.toggleFavId('${song.id}', event)">
                            <i class="fa-${isFav ? 'solid' : 'regular'} fa-heart"></i>
                        </button>
                    `;
                    box.appendChild(el);
                });
            },

            renderCategories() {
                const cats = [...new Set(DB.map(s => s.category))];
                const list = document.getElementById('category-list');
                cats.forEach(c => {
                    const li = document.createElement('li');
                    li.className = 'nav-item';
                    li.innerHTML = `<i class="fa-solid fa-layer-group"></i> ${c}`;
                    li.onclick = (e) => this.setMenu('category', c);
                    list.appendChild(li);
                });
            },

            playSpecific(id) {
                // Ensure we are playing from the currently filtered list
                const idx = this.state.list.findIndex(s => s.id === id);
                if(idx !== -1) {
                    this.state.index = idx;
                    this.loadSong(this.state.list[this.state.index], true);
                }
            },

            toggleShuffle() {
                this.state.isShuffle = !this.state.isShuffle;
                localStorage.setItem('neu_shuffle', this.state.isShuffle);
                this.updateControlButtons();
                this.toast(`Shuffle ${this.state.isShuffle ? 'On' : 'Off'}`);
            },

            toggleRepeat() {
                this.state.repeatMode = (this.state.repeatMode + 1) % 3;
                localStorage.setItem('neu_repeat', this.state.repeatMode);
                this.updateControlButtons();
                const text = ["Off", "All", "One"];
                this.toast(`Repeat ${text[this.state.repeatMode]}`);
            },

            updateControlButtons() {
                const shuf = document.getElementById('btn-shuffle');
                const rep = document.getElementById('btn-repeat');
                
                shuf.style.color = this.state.isShuffle ? 'var(--primary)' : 'var(--text-main)';
                shuf.classList.toggle('neu-pressed', this.state.isShuffle);
                
                rep.style.color = this.state.repeatMode > 0 ? 'var(--primary)' : 'var(--text-main)';
                rep.classList.toggle('neu-pressed', this.state.repeatMode > 0);
                
                if(this.state.repeatMode === 2) rep.innerHTML = '<i class="fa-solid fa-repeat"></i><span style="position:absolute; font-size:9px; font-weight:bold; margin-top:-10px;">1</span>';
                else rep.innerHTML = '<i class="fa-solid fa-repeat"></i>';
            },

            toggleFavId(id, event) {
                if(event) event.stopPropagation();
                const song = DB.find(s => s.id === id);
                const idx = this.state.favorites.findIndex(s => s.id === id);
                
                if(idx === -1) {
                    this.state.favorites.push(song);
                    this.toast("Added to Favorites ❤️");
                } else {
                    this.state.favorites.splice(idx, 1);
                    this.toast("Removed from Favorites");
                }
                localStorage.setItem('neu_favs', JSON.stringify(this.state.favorites));
                
                // Re-render if in fav view
                if(this.state.view === 'favorites') this.renderList();
                else {
                    // Just update button visual
                    const btn = event.currentTarget;
                    btn.classList.toggle('is-fav');
                    btn.querySelector('i').className = `fa-${idx === -1 ? 'solid' : 'regular'} fa-heart`;
                }
                
                // Update hero if it's the current song
                if(id === DB[this.state.index]?.id) this.updateFavIcon();
            },

            toggleFavCurrent() {
                const cur = this.state.list[this.state.index];
                if(cur) this.toggleFavId(cur.id, null);
            },

            updateFavIcon() {
                const cur = this.state.list[this.state.index];
                if(!cur) return;
                const isFav = this.state.favorites.some(s => s.id === cur.id);
                const btn = document.getElementById('hero-fav-btn');
                btn.style.color = isFav ? 'var(--danger)' : 'var(--text-main)';
                btn.querySelector('i').className = `fa-${isFav ? 'solid' : 'regular'} fa-heart`;
            },

            addToRecent(song) {
                this.state.recent = this.state.recent.filter(s => s.id !== song.id);
                this.state.recent.unshift(song);
                if(this.state.recent.length > 20) this.state.recent.pop();
                localStorage.setItem('neu_recent', JSON.stringify(this.state.recent));
                if(this.state.view === 'recent') this.renderList();
            },

            updateTimeUI() {
                const d = this.audio.duration;
                const c = this.audio.currentTime;
                if(isNaN(d)) return;
                
                document.getElementById('seek-bar').value = (c / d) * 100;
                document.getElementById('time-cur').textContent = this.formatTime(c);
                document.getElementById('time-tot').textContent = this.formatTime(d);
                
                this.syncLyrics(c, d);
            },

            formatTime(sec) {
                let m = Math.floor(sec / 60);
                let s = Math.floor(sec % 60);
                return `${m}:${s < 10 ? '0'+s : s}`;
            },

            renderLyrics(song) {
                const box = document.getElementById('lyrics-container');
                box.innerHTML = '';
                if(song.lyrics && song.lyrics.length > 0) {
                    song.lyrics.forEach((l, i) => {
                        let p = document.createElement('p');
                        p.className = 'lyric-line';
                        p.id = `lyr-${i}`;
                        p.textContent = l;
                        box.appendChild(p);
                    });
                } else {
                    box.innerHTML = '<p>No lyrics available.</p>';
                }
            },

            syncLyrics(current, total) {
                const lines = document.querySelectorAll('.lyric-line');
                if(lines.length === 0) return;
                
                const timePerLine = total / lines.length;
                let active = Math.floor(current / timePerLine);
                if(active >= lines.length) active = lines.length - 1;

                lines.forEach((l, i) => {
                    if(i === active) {
                        if(!l.classList.contains('active')) {
                            l.classList.add('active');
                            l.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    } else l.classList.remove('active');
                });
            },

            toggleMute() {
                this.audio.muted = !this.audio.muted;
                const i = document.querySelector('#btn-mute i');
                i.className = this.audio.muted ? 'fa-solid fa-volume-xmark' : 'fa-solid fa-volume-high';
                document.getElementById('btn-mute').classList.toggle('neu-pressed', this.audio.muted);
            },

            toggleTheme(forceDark = null) {
                const html = document.documentElement;
                let isDark;
                if(forceDark !== null) {
                    isDark = forceDark;
                    if(isDark) html.classList.add('dark');
                    else html.classList.remove('dark');
                } else {
                    isDark = html.classList.toggle('dark');
                }
                
                localStorage.setItem('neu_dark', isDark);
                document.getElementById('theme-text').textContent = isDark ? 'Light Mode' : 'Dark Mode';
                document.getElementById('theme-icon').className = isDark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
            },

            toast(msg) {
                const box = document.getElementById('toast-box');
                const t = document.createElement('div');
                t.className = 'toast';
                t.innerHTML = `<i class="fa-solid fa-info-circle" style="color:var(--primary); margin-right:8px;"></i> ${msg}`;
                box.appendChild(t);
                setTimeout(() => {
                    t.style.animation = 'slideIn 0.3s ease reverse forwards';
                    setTimeout(() => t.remove(), 300);
                }, 3000);
            },

            bindEvents() {
                // Audio Native Events
                this.audio.addEventListener('timeupdate', () => this.updateTimeUI());
                this.audio.addEventListener('ended', () => {
                    if(this.state.repeatMode === 2) {
                        this.audio.currentTime = 0;
                        this.play();
                    } else if(this.state.repeatMode === 1 || this.state.index < this.state.list.length - 1) {
                        this.next();
                    } else {
                        this.pause();
                        this.state.index = 0;
                        this.loadSong(this.state.list[0], false);
                    }
                });
                this.audio.addEventListener('playing', () => {
                    document.getElementById('btn-play').classList.remove('is-loading');
                });
                this.audio.addEventListener('waiting', () => {
                    document.getElementById('btn-play').classList.add('is-loading');
                });

                // Sliders
                document.getElementById('seek-bar').addEventListener('input', (e) => {
                    const d = this.audio.duration;
                    if(!isNaN(d)) this.audio.currentTime = (e.target.value / 100) * d;
                });
                document.getElementById('vol-bar').addEventListener('input', (e) => {
                    this.audio.volume = e.target.value / 100;
                    localStorage.setItem('neu_vol', this.audio.volume);
                    if(this.audio.muted) this.toggleMute();
                });

                // Search
                document.getElementById('search-input').addEventListener('input', (e) => this.search(e.target.value));

                // Keyboard
                document.addEventListener('keydown', (e) => {
                    if(e.target.tagName === 'INPUT') return;
                    switch(e.code) {
                        case 'Space': e.preventDefault(); this.togglePlay(); break;
                        case 'ArrowRight': this.next(); break;
                        case 'ArrowLeft': this.prev(); break;
                        case 'KeyM': this.toggleMute(); break;
                    }
                });
            }
        };

        /**
         * Because standard AudioContext analysis fails cross-origin on most audio urls, 
         * this is a high-performance mathematical simulation that generates organic
         * frequency-like patterns syncing with the play state and volume.
         */
        const Visualizer = {
            canvas: null,
            ctx: null,
            dataArray: new Uint8Array(64), // 64 frequency bars around circle
            frameId: null,
            time: 0,
            
            init() {
                this.canvas = document.getElementById('freq-canvas');
                this.ctx = this.canvas.getContext('2d');
                this.resize();
                window.addEventListener('resize', () => this.resize());
                
                // Draw initial flat circle
                this.draw();
            },
            
            resize() {
                // High DPI Canvas for crisp lines
                const rect = this.canvas.parentElement.getBoundingClientRect();
                this.canvas.width = rect.width * window.devicePixelRatio;
                this.canvas.height = rect.height * window.devicePixelRatio;
                this.ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
            },
            
            start() {
                if(!this.frameId) this.animate();
            },
            
            stop() {
                // Let the animation loop smoothly drop the bars to zero before stopping
            },
            
            animate() {
                this.time += 0.05;
                let allZero = true;
                
                const vol = app.audio.muted ? 0 : app.audio.volume;
                const targetMult = app.state.isPlaying ? vol * 120 : 0; // Max height expansion

                // Simulate FFT Data using noise/sine waves
                for(let i = 0; i < this.dataArray.length; i++) {
                    let target = 0;
                    if(app.state.isPlaying && targetMult > 0) {
                        // Generate a realistic looking frequency spectrum
                        // Bass (lower indices), Mids, Treble
                        const normIndex = i / this.dataArray.length; 
                        
                        // Fake Bass pulse
                        const bass = Math.sin(this.time * 2) * (1 - normIndex) * 1.5;
                        // Fake erratic Mids/Treble
                        const noise = Math.sin(this.time * 5 + i) * Math.cos(this.time * 3 - i*2);
                        
                        // Combine and add random flicker
                        target = Math.abs((bass + noise) * targetMult * Math.random());
                    }
                    
                    // Smooth easing (lerp)
                    this.dataArray[i] += (target - this.dataArray[i]) * 0.15;
                    
                    if(this.dataArray[i] > 1) allZero = false;
                }
                
                this.draw();
                
                if(app.state.isPlaying || !allZero) {
                    this.frameId = requestAnimationFrame(() => this.animate());
                } else {
                    this.frameId = null; // Completely stopped
                }
            },
            
            draw() {
                const width = this.canvas.width / window.devicePixelRatio;
                const height = this.canvas.height / window.devicePixelRatio;
                const centerX = width / 2;
                const centerY = height / 2;
                const radius = (width / 2) - 30; // Inner radius
                
                this.ctx.clearRect(0, 0, width, height);
                
                // Set style based on theme
                const isDark = document.documentElement.classList.contains('dark');
                this.ctx.strokeStyle = isDark ? '#a29bfe' : '#6c5ce7'; // Primary color
                this.ctx.lineWidth = 3;
                this.ctx.lineCap = 'round';
                
                const bars = this.dataArray.length;
                const angleStep = (Math.PI * 2) / bars;
                
                for(let i = 0; i < bars; i++) {
                    const amplitude = this.dataArray[i] * 0.4; // scale down visual height
                    const angle = i * angleStep;
                    
                    // Start point (on the inner circle)
                    const startX = centerX + Math.cos(angle) * radius;
                    const startY = centerY + Math.sin(angle) * radius;
                    
                    // End point (pushed outwards by amplitude)
                    const endX = centerX + Math.cos(angle) * (radius + amplitude);
                    const endY = centerY + Math.sin(angle) * (radius + amplitude);
                    
                    this.ctx.beginPath();
                    this.ctx.moveTo(startX, startY);
                    this.ctx.lineTo(endX, endY);
                    this.ctx.stroke();
                }
            }
        };

        // Bootstrap Application
        document.addEventListener('DOMContentLoaded', () => app.init());

    </script>
</body>
</html>
